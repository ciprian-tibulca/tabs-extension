{
  "manifest_version": 3,
  "name": "Close Tab Group",
  "version": "1.0",
  "description": "Closes the current tab group, or the current tab if ungrouped.",
  "permissions": ["tabGroups"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Close tab group (or tab)"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
